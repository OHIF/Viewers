# =============================================================================
# Orthanc DICOM backend (MIMPS-05) — consumed by docker-compose.yml.
# Copy this file to .env (gitignored) and fill in real values before
# `docker compose up -d`. Every variable below is REQUIRED by the compose stack.
# =============================================================================

# Orthanc HTTP Basic credentials. Injected into Orthanc via
# ORTHANC__REGISTERED_USERS and into the orthanc-nginx gateway, which adds the
# Authorization header server-side so the browser never sees them.
ORTHANC_USERNAME=mimps
# Generate a strong value, e.g. `openssl rand -base64 24`. Compose fails fast if unset.
ORTHANC_PASSWORD=

# Browser origin allowed by the orthanc-nginx gateway CORS headers.
#   local dev:   http://localhost:3000
#   production:  https://viewer.blackvoxel.ai
# In production the app and /pacs/ are same-origin (served by the host nginx),
# so CORS is not strictly exercised, but this must still match the viewer origin.
MIMPS_VIEWER_ORIGIN=http://localhost:3000

# Data-residency tag (MIMPS-18 / ANVISA-LGPD groundwork). Keep a "br-*" value for
# Brazilian deployments. Not yet enforced by any service.
DICOM_STORAGE_REGION=br-local

# BlackVoxel platform integration
BLACKVOXEL_JWKS_URL=https://blackvoxel.ai/api/auth/.well-known/jwks.json
BLACKVOXEL_JWT_AUDIENCE=

# Set to true to re-enable htpasswd gate (mount docker/nginx.htpasswd.conf instead of docker/nginx.conf)
HTPASSWD_FALLBACK=false

# BlackVoxel platform API base URL for inference requests (used by blackvoxel-ai extension)
# Build-time env var: set in your build environment, not at runtime
BLACKVOXEL_API_URL=https://blackvoxel.ai

# BlackVoxel platform URL shown as "← BlackVoxel Platform" link in the MIMPS viewer header
# Build-time env var. If unset, the link is hidden entirely.
BLACKVOXEL_PLATFORM_URL=https://blackvoxel.ai
