#!/usr/bin/env bun

import { $ } from "bun";
import fs from "fs";
import path from "path";

async function ensureWorktree(branchSpec: string, repoRoot: string) {
  const libsDir = path.join(repoRoot, "libs");
  const worktreeDir = path.join(libsDir, "@cornerstonejs");
  const cornerstoneBaseDir = path.resolve(repoRoot, "..", "cornerstone3D");

  if (!fs.existsSync(cornerstoneBaseDir)) {
    console.error(
      `Expected cornerstone3D repo at ../cornerstone3D (resolved to ${cornerstoneBaseDir}).`
    );
    process.exit(1);
  }

  if (!fs.existsSync(libsDir)) {
    fs.mkdirSync(libsDir, { recursive: true });
  }

  const worktreeGitDir = path.join(worktreeDir, ".git");
  if (fs.existsSync(worktreeGitDir)) {
    console.log(`Reusing existing worktree at ${worktreeDir}`);
    return { worktreeDir, cornerstoneBaseDir };
  }

  let remote: string | null = null;
  let branchName = branchSpec;

  const colonIndex = branchSpec.indexOf(":");
  if (colonIndex !== -1) {
    remote = branchSpec.slice(0, colonIndex);
    branchName = branchSpec.slice(colonIndex + 1);
  }

  if (remote) {
    console.log(`Fetching from remote '${remote}' in ${cornerstoneBaseDir}...`);
    const fetchResult = await $`git -C ${cornerstoneBaseDir} fetch ${remote}`.nothrow();
    if (fetchResult.exitCode !== 0) {
      console.error("git fetch failed");
      process.exit(fetchResult.exitCode ?? 1);
    }
  }

  let worktreeCmd;

  if (remote) {
    // Create a local branch tracking the remote one.
    worktreeCmd = $`git -C ${cornerstoneBaseDir} worktree add -b ${branchName} ${worktreeDir} ${remote}/${branchName}`;
  } else {
    // If branch exists locally, use it directly; otherwise create from origin/branchName.
    const check = await $`git -C ${cornerstoneBaseDir} rev-parse --verify ${branchName}`.nothrow();
    if (check.exitCode === 0) {
      worktreeCmd = $`git -C ${cornerstoneBaseDir} worktree add ${worktreeDir} ${branchName}`;
    } else {
      worktreeCmd = $`git -C ${cornerstoneBaseDir} worktree add -b ${branchName} ${worktreeDir} origin/${branchName}`;
    }
  }

  console.log(
    `Adding worktree for branch '${branchName}' from ${cornerstoneBaseDir} into ${worktreeDir}...`
  );
  const worktreeResult = await worktreeCmd.nothrow();
  if (worktreeResult.exitCode !== 0) {
    console.error("git worktree add failed");
    process.exit(worktreeResult.exitCode ?? 1);
  }

  return { worktreeDir, cornerstoneBaseDir };
}

function findSourcePathForPackage(worktreeDir: string, pkgName: string) {
  const candidates = [
    path.join(worktreeDir, "packages", pkgName),
    path.join(worktreeDir, "packages", "@cornerstonejs", pkgName),
    path.join(worktreeDir, pkgName),
    path.join(worktreeDir, "@cornerstonejs", pkgName),
  ];

  for (const candidate of candidates) {
    if (fs.existsSync(candidate) && fs.lstatSync(candidate).isDirectory()) {
      return candidate;
    }
  }

  return null;
}

async function linkPackages(worktreeDir: string, repoRoot: string) {
  const nodeModulesScopeDir = path.join(
    repoRoot,
    "node_modules",
    "@cornerstonejs"
  );

  if (!fs.existsSync(nodeModulesScopeDir)) {
    console.error(
      `Expected node_modules/@cornerstonejs to exist at ${nodeModulesScopeDir}.`
    );
    process.exit(1);
  }

  const entries = fs.readdirSync(nodeModulesScopeDir, {
    withFileTypes: true,
  });

  for (const entry of entries) {
    if (!entry.isDirectory()) {
      continue;
    }

    const pkgName = entry.name;
    const target = findSourcePathForPackage(worktreeDir, pkgName);

    if (!target) {
      console.warn(
        `No source directory found for @cornerstonejs/${pkgName} in worktree; skipping.`
      );
      continue;
    }

    const linkPath = path.join(nodeModulesScopeDir, pkgName);

    try {
      fs.rmSync(linkPath, { recursive: true, force: true });
    } catch (err) {
      console.warn(
        `Failed to remove existing @cornerstonejs/${pkgName} at ${linkPath}:`,
        err
      );
      continue;
    }

    const symlinkType = process.platform === "win32" ? "junction" : "dir";

    try {
      fs.symlinkSync(target, linkPath, symlinkType as fs.symlink.Type);
      console.log(
        `Linked @cornerstonejs/${pkgName} -> ${path.relative(
          repoRoot,
          target
        )}`
      );
    } catch (err) {
      console.error(
        `Failed to create symlink for @cornerstonejs/${pkgName}:`,
        err
      );
    }
  }
}

async function main() {
  const branchSpec = process.argv[2];

  if (!branchSpec) {
    console.error(
      "Usage: bun .scripts/worktree <branch | remote:branch>, e.g. jbocce:fix/OHIF-2354-SR-spline-live-wire"
    );
    process.exit(1);
  }

  const repoRoot = process.cwd();

  const { worktreeDir } = await ensureWorktree(branchSpec, repoRoot);
  await linkPackages(worktreeDir, repoRoot);
}

main().catch((err) => {
  console.error(err);
  process.exit(1);
});

