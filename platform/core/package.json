{
  "name": "@ohif/core",
  "version": "3.13.0-beta.127",
  "description": "Generic business logic for web-based medical imaging applications",
  "author": "OHIF Core Team",
  "license": "MIT",
  "repository": "OHIF/Viewers",
  "main": "dist/ohif-core.umd.js",
  "module": "src/index.ts",
  "types": "src/types/index.ts",
  "engines": {
    "node": ">=24"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": "false",
  "scripts": {
    "clean": "shx rm -rf dist",
    "clean:deep": "pnpm run clean && shx rm -rf node_modules",
    "dev": "jest --watchAll",
    "dev:core": "pnpm run dev",
    "build": "cross-env NODE_ENV=production rspack build --config .webpack/webpack.prod.js",
    "build:package": "pnpm run build",
    "start": "pnpm run dev",
    "test:unit": "jest --watchAll",
    "test:unit:ci": "jest --ci --runInBand --collectCoverage"
  },
  "peerDependencies": {
    "@cornerstonejs/codec-charls": "1.2.3",
    "@cornerstonejs/codec-libjpeg-turbo-8bit": "1.2.2",
    "@cornerstonejs/codec-openjpeg": "1.3.0",
    "@cornerstonejs/codec-openjph": "2.4.7",
    "@cornerstonejs/core": "5.6.1",
    "@cornerstonejs/dicom-image-loader": "5.6.1",
    "@cornerstonejs/metadata": "5.6.1",
    "@ohif/ui": "workspace:*",
    "cornerstone-math": "0.1.10",
    "dicom-parser": "1.8.21"
  },
  "dependencies": {
    "@babel/runtime": "7.29.7",
    "dcmjs": "0.52.0",
    "dicomweb-client": "0.10.4",
    "gl-matrix": "3.4.3",
    "immutability-helper": "3.1.1",
    "isomorphic-base64": "1.0.2",
    "json5": "2.2.3",
    "lodash.clonedeep": "4.5.0",
    "lodash.isequal": "4.5.0",
    "moment": "2.30.1",
    "object-hash": "2.1.1",
    "query-string": "6.14.1",
    "shepherd.js": "15.2.2",
    "validate.js": "0.12.0"
  },
  "devDependencies": {
    "webpack-merge": "5.10.0"
  }
}
