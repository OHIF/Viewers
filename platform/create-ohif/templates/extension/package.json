{
  "name": "{{name}}",
  "version": "0.0.1",
  "description": "{{description}}",
  "license": "MIT",
  "keywords": [
    "ohif-extension"
  ],
  "main": "dist/index.umd.js",
  "module": "src/index.tsx",
  "engines": {
    "node": ">=24"
  },
  "files": [
    "dist",
    "src",
    "public",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "main": "dist/index.umd.js",
    "module": "dist/index.umd.js"
  },
  "scripts": {
    "dev": "cross-env NODE_ENV=development rspack build --config .rspack/rspack.prod.js --watch",
    "build": "cross-env NODE_ENV=production rspack build --config .rspack/rspack.prod.js",
    "build:package": "pnpm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit:ci": "vitest run --passWithNoTests"
  },
  "peerDependencies": {
    "@ohif/core": "{{peerRange}}",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@rspack/cli": "^2.0.0",
    "@rspack/core": "^2.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "cross-env": "^7.0.3",
    "css-loader": "^6.11.0",
    "postcss": "^8.4.0",
    "postcss-loader": "^8.1.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "style-loader": "^4.0.0",
    "tailwindcss": "3.2.4",
    "typescript": "^5.5.0",
    "vitest": "^3.2.0"
  }
}
