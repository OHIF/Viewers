{
  "name": "@ohif/extension-measurement-tracking",
  "version": "3.13.0-beta.134",
  "description": "Tracking features and functionality for basic image viewing",
  "author": "OHIF Core Team",
  "license": "MIT",
  "repository": "OHIF/Viewers",
  "main": "dist/ohif-extension-measurement-tracking.umd.js",
  "module": "src/index.tsx",
  "engines": {
    "node": ">=24"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "shx rm -rf dist",
    "clean:deep": "pnpm run clean && shx rm -rf node_modules",
    "dev": "cross-env REACT_COMPILER=off NODE_ENV=development rspack build --config .webpack/webpack.dev.js --watch",
    "dev:dicom-pdf": "pnpm run dev",
    "build": "cross-env REACT_COMPILER=off NODE_ENV=production rspack build --config .webpack/webpack.prod.js",
    "build:package-1": "pnpm run build",
    "start": "pnpm run dev"
  },
  "peerDependencies": {
    "@cornerstonejs/core": "5.6.8",
    "@cornerstonejs/tools": "5.6.8",
    "@ohif/core": "workspace:*",
    "@ohif/extension-cornerstone-dicom-sr": "workspace:*",
    "@ohif/extension-default": "workspace:*",
    "classnames": "2.5.1",
    "dcmjs": "0.52.0",
    "lodash.debounce": "4.0.8",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "webpack-merge": "5.10.0"
  },
  "dependencies": {
    "@babel/runtime": "7.29.7",
    "@xstate/react": "3.2.2",
    "xstate": "4.38.3"
  },
  "devDependencies": {
    "cross-env": "7.0.3",
    "webpack-merge": "5.10.0"
  },
  "keywords": [
    "ohif-extension"
  ]
}
